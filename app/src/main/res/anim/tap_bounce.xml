<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:fillAfter="true">

    <scale
        android:duration="80"
        android:fromXScale="1.0"
        android:fromYScale="1.0"
        android:pivotX="50%"
        android:pivotY="50%"
        android:toXScale="0.88"
        android:toYScale="0.88" />

    <scale
        android:duration="100"
        android:fromXScale="0.88"
        android:fromYScale="0.88"
        android:pivotX="50%"
        android:pivotY="50%"
        android:startOffset="80"
        android:toXScale="1.08"
        android:toYScale="1.08" />

    <scale
        android:duration="80"
        android:fromXScale="1.08"
        android:fromYScale="1.08"
        android:pivotX="50%"
        android:pivotY="50%"
        android:startOffset="180"
        android:toXScale="1.0"
        android:toYScale="1.0" />

</set>
